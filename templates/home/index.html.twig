{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<div class="hero-section text-white rounded-3 p-5 mb-5 text-center">
    <h1 class="display-4 fw-bold mb-3">
        <i class="bi bi-book-half me-3"></i>Bienvenue à la Bibliothèque
    </h1>
    <p class="lead mb-4">Découvrez notre collection de livres et empruntez vos favoris facilement.</p>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
        <a href="{{ path('app_books') }}" class="btn btn-warning btn-lg fw-bold">
            <i class="bi bi-search me-2"></i>Parcourir les livres
        </a>
        {% if not is_granted('ROLE_USER') %}
            <a href="{{ path('app_register') }}" class="btn btn-outline-light btn-lg">
                <i class="bi bi-person-plus me-2"></i>Créer un compte
            </a>
        {% endif %}
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card text-center border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <i class="bi bi-collection-fill display-4 text-primary mb-3"></i>
                <h5 class="card-title">Large collection</h5>
                <p class="card-text text-muted">Des milliers de livres disponibles dans de nombreuses catégories.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card text-center border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <i class="bi bi-lightning-charge display-4 text-warning mb-3"></i>
                <h5 class="card-title">Emprunt rapide</h5>
                <p class="card-text text-muted">Empruntez un livre en un clic depuis votre espace personnel.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card text-center border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <i class="bi bi-arrow-repeat display-4 text-success mb-3"></i>
                <h5 class="card-title">Suivi des emprunts</h5>
                <p class="card-text text-muted">Suivez vos emprunts et dates de retour facilement.</p>
            </div>
        </div>
    </div>
</div>

{% if recentBooks|length > 0 %}
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-stars text-warning me-2"></i>Dernières acquisitions
        </h2>
        <a href="{{ path('app_books') }}" class="btn btn-outline-primary">
            Voir tous les livres <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>
    <div class="row g-4">
        {% for book in recentBooks %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex gap-3 align-items-start p-3">
                        <div class="flex-shrink-0 text-center p-2 rounded bg-primary bg-opacity-10" style="width:52px;">
                            <i class="bi bi-book text-primary fs-4"></i>
                        </div>
                        <div class="flex-grow-1 overflow-hidden">
                            <h6 class="fw-bold mb-1 text-truncate">{{ book.titre }}</h6>
                            {% if book.auteur %}
                                <p class="text-muted small mb-1 text-truncate">{{ book.auteur }}</p>
                            {% endif %}
                            {% if book.category %}
                                <span class="badge bg-secondary bg-opacity-75 text-white small">{{ book.category.nom }}</span>
                            {% endif %}
                            <div class="mt-2">
                                <a href="{{ path('app_book_show', {id: book.id}) }}" class="btn btn-sm btn-outline-primary">
                                    Voir le détail
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% if categories|length > 0 %}
<div class="mb-5">
    <h2 class="fw-bold mb-4">
        <i class="bi bi-tags text-primary me-2"></i>Parcourir par catégorie
    </h2>
    <div class="row g-3">
        {% for category in categories %}
            <div class="col-md-3 col-sm-4 col-6">
                <a href="{{ path('app_books', {category: category.id}) }}" class="text-decoration-none">
                    <div class="card border-0 shadow-sm text-center p-3">
                        <i class="bi bi-folder2-open text-primary mb-2" style="font-size: 2rem;"></i>
                        <h6 class="mb-0">{{ category.nom }}</h6>
                        <small class="text-muted">{{ category.books|length }} livre(s)</small>
                    </div>
                </a>
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}
