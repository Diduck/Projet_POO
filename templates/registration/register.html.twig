{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus display-3 text-primary"></i>
                    <h2 class="fw-bold mt-2">Créer un compte</h2>
                    <p class="text-muted">Rejoignez notre bibliothèque</p>
                </div>

                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="mb-3">
                    {{ form_label(form.email, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control' ~ (form.email.vars.errors|length > 0 ? ' is-invalid' : ''), 'placeholder': 'votre@email.fr'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div class="mb-3">
                    {{ form_row(form.plainPassword.first, {'label_attr': {'class': 'form-label fw-semibold'}, 'attr': {'placeholder': 'Au moins 6 caractères'}}) }}
                </div>

                <div class="mb-4">
                    {{ form_row(form.plainPassword.second, {'label_attr': {'class': 'form-label fw-semibold'}, 'attr': {'placeholder': 'Répétez le mot de passe'}}) }}
                    {{ form_errors(form.plainPassword) }}
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-lg">
                    <i class="bi bi-person-check me-2"></i>Créer mon compte
                </button>

                {{ form_end(form) }}

                <hr class="my-4">

                <div class="text-center">
                    <p class="text-muted mb-0">Déjà un compte ?
                        <a href="{{ path('app_login') }}" class="fw-semibold">Se connecter</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
