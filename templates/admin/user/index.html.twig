{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Admin</a></li>
            <li class="breadcrumb-item active">Utilisateurs</li>
        </ol>
    </nav>
    <h1 class="fw-bold mb-0"><i class="bi bi-people me-2 text-info"></i>Gestion des utilisateurs</h1>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Email</th>
                    <th>Rôles</th>
                    <th>Emprunts</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td class="text-muted small">{{ user.id }}</td>
                    <td>
                        <i class="bi bi-person-circle me-2 text-muted"></i>
                        {{ user.email }}
                        {% if user.email == app.user.email %}
                            <span class="badge bg-info text-dark ms-1">Vous</span>
                        {% endif %}
                    </td>
                    <td>
                        {% for role in user.roles %}
                            {% if role == 'ROLE_ADMIN' %}
                                <span class="badge bg-warning text-dark me-1">Admin</span>
                            {% elseif role == 'ROLE_USER' %}
                                <span class="badge bg-primary me-1">Utilisateur</span>
                            {% endif %}
                        {% endfor %}
                    </td>
                    <td>
                        <span class="badge bg-secondary">{{ user.loans|length }} emprunt(s)</span>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">Aucun utilisateur trouvé.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-transparent text-muted small">
        {{ users|length }} utilisateur(s) au total
    </div>
</div>
{% endblock %}
