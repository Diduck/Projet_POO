{% extends 'base.html.twig' %}

{% block title %}Gestion des livres{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Admin</a></li>
                <li class="breadcrumb-item active">Livres</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-0"><i class="bi bi-book me-2 text-primary"></i>Gestion des livres</h1>
    </div>
    <a href="{{ path('admin_books_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Ajouter un livre
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Titre</th>
                    <th>Auteur</th>
                    <th>Catégorie</th>
                    <th>Publication</th>
                    <th>Disponibilité</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for book in books %}
                <tr>
                    <td class="text-muted small">{{ book.id }}</td>
                    <td class="fw-semibold">{{ book.titre }}</td>
                    <td class="text-muted">{{ book.auteur ?? '—' }}</td>
                    <td>
                        {% if book.category %}
                            <span class="badge bg-secondary">{{ book.category.nom }}</span>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>{{ book.datePublication ? book.datePublication|date('d/m/Y') : '—' }}</td>
                    <td>
                        {% if book.disponible %}
                            <span class="badge bg-success">Disponible</span>
                        {% else %}
                            <span class="badge bg-danger">Indisponible</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="{{ path('app_book_show', {id: book.id}) }}" class="btn btn-sm btn-outline-info" title="Voir">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('admin_books_edit', {id: book.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_books_delete', {id: book.id}) }}"
                                  onsubmit="return confirm('Supprimer ce livre ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Aucun livre trouvé.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-transparent text-muted small">
        {{ books|length }} livre(s) au total
    </div>
</div>
{% endblock %}
