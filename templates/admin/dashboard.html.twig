{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}
<div class="row">
    {# Admin Sidebar #}
    <div class="col-md-2 mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3">
                <h6 class="text-muted text-uppercase small fw-bold mb-3 px-2">Navigation</h6>
                <nav class="nav flex-column sidebar-admin">
                    <a href="{{ path('admin_dashboard') }}" class="nav-link active">
                        <i class="bi bi-speedometer2 me-2"></i>Tableau de bord
                    </a>
                    <a href="{{ path('admin_books_list') }}" class="nav-link">
                        <i class="bi bi-book me-2"></i>Livres
                    </a>
                    <a href="{{ path('admin_categories_list') }}" class="nav-link">
                        <i class="bi bi-tags me-2"></i>Catégories
                    </a>
                    <a href="{{ path('admin_loans_list') }}" class="nav-link">
                        <i class="bi bi-arrow-left-right me-2"></i>Emprunts
                    </a>
                    <a href="{{ path('admin_users_list') }}" class="nav-link">
                        <i class="bi bi-people me-2"></i>Utilisateurs
                    </a>
                </nav>
            </div>
        </div>
    </div>

    <div class="col-md-10">
        <h1 class="fw-bold mb-4"><i class="bi bi-speedometer2 me-2 text-primary"></i>Tableau de bord</h1>

        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4">
                    <i class="bi bi-book display-4 text-primary mb-2"></i>
                    <h2 class="fw-bold">{{ totalBooks }}</h2>
                    <p class="text-muted mb-0">Livres total</p>
                    <small class="text-success"><i class="bi bi-check-circle me-1"></i>{{ availableBooks }} disponibles</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4">
                    <i class="bi bi-tags display-4 text-warning mb-2"></i>
                    <h2 class="fw-bold">{{ totalCategories }}</h2>
                    <p class="text-muted mb-0">Catégories</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4">
                    <i class="bi bi-people display-4 text-info mb-2"></i>
                    <h2 class="fw-bold">{{ totalUsers }}</h2>
                    <p class="text-muted mb-0">Utilisateurs</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4">
                    <i class="bi bi-bookmark display-4 text-success mb-2"></i>
                    <h2 class="fw-bold">{{ activeLoans }}</h2>
                    <p class="text-muted mb-0">Emprunts actifs</p>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <a href="{{ path('admin_books_new') }}" class="btn btn-primary w-100 py-3">
                    <i class="bi bi-plus-circle me-2"></i>Ajouter un livre
                </a>
            </div>
            <div class="col-md-4">
                <a href="{{ path('admin_categories_new') }}" class="btn btn-warning w-100 py-3">
                    <i class="bi bi-plus-circle me-2"></i>Ajouter une catégorie
                </a>
            </div>
            <div class="col-md-4">
                <a href="{{ path('admin_loans_list') }}" class="btn btn-success w-100 py-3">
                    <i class="bi bi-list-check me-2"></i>Gérer les emprunts
                </a>
            </div>
        </div>

        {% if recentLoans|length > 0 %}
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h5 class="fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Derniers emprunts</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Livre</th>
                            <th>Utilisateur</th>
                            <th>Emprunté le</th>
                            <th>Retour prévu</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for loan in recentLoans %}
                        <tr>
                            <td><a href="{{ path('app_book_show', {id: loan.book.id}) }}" class="text-decoration-none">{{ loan.book.titre }}</a></td>
                            <td>{{ loan.user.email }}</td>
                            <td>{{ loan.dateEmprunt|date('d/m/Y') }}</td>
                            <td>{{ loan.dateRetourPrevue|date('d/m/Y') }}</td>
                            <td>
                                {% if loan.statut == 'en_cours' %}
                                    <span class="badge bg-info text-dark">En cours</span>
                                {% elseif loan.statut == 'rendu' %}
                                    <span class="badge bg-success">Rendu</span>
                                {% else %}
                                    <span class="badge bg-danger">En retard</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-transparent text-end">
                <a href="{{ path('admin_loans_list') }}" class="btn btn-sm btn-outline-primary">Voir tous les emprunts</a>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
