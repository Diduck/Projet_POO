{% extends 'base.html.twig' %}

{% block title %}Modifier : {{ category.nom }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Admin</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_categories_list') }}">Catégories</a></li>
        <li class="breadcrumb-item active">Modifier</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h2 class="fw-bold"><i class="bi bi-pencil me-2 text-warning"></i>Modifier la catégorie</h2>
                <p class="text-muted">{{ category.nom }}</p>
            </div>
            <div class="card-body p-4">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                {{ form_row(form.nom) }}
                {{ form_row(form.description) }}
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save me-1"></i>Enregistrer les modifications
                    </button>
                    <a href="{{ path('admin_categories_list') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Annuler
                    </a>
                </div>
                {{ form_end(form) }}
                <form method="post" action="{{ path('admin_categories_delete', {id: category.id}) }}"
                      onsubmit="return confirm('Supprimer cette catégorie ?')" class="mt-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                    <button class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Supprimer cette catégorie
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
