{% extends 'base.html.twig' %}

{% block title %}Gestion des catégories{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Admin</a></li>
                <li class="breadcrumb-item active">Catégories</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-0"><i class="bi bi-tags me-2 text-warning"></i>Gestion des catégories</h1>
    </div>
    <a href="{{ path('admin_categories_new') }}" class="btn btn-warning">
        <i class="bi bi-plus-circle me-1"></i>Ajouter une catégorie
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Livres</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for category in categories %}
                <tr>
                    <td class="text-muted small">{{ category.id }}</td>
                    <td class="fw-semibold">{{ category.nom }}</td>
                    <td class="text-muted small">
                        {{ category.description|length > 80 ? category.description|slice(0, 80) ~ '...' : category.description }}
                    </td>
                    <td>
                        <span class="badge bg-secondary">{{ category.books|length }}</span>
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="{{ path('admin_categories_edit', {id: category.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_categories_delete', {id: category.id}) }}"
                                  onsubmit="return confirm('Supprimer cette catégorie ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">Aucune catégorie trouvée.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-transparent text-muted small">
        {{ categories|length }} catégorie(s) au total
    </div>
</div>
{% endblock %}
