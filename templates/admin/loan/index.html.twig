{% extends 'base.html.twig' %}

{% block title %}Gestion des emprunts{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Admin</a></li>
                <li class="breadcrumb-item active">Emprunts</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-0"><i class="bi bi-arrow-left-right me-2 text-success"></i>Gestion des emprunts</h1>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Livre</th>
                    <th>Utilisateur</th>
                    <th>Emprunté le</th>
                    <th>Retour prévu</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for loan in loans %}
                <tr>
                    <td class="text-muted small">{{ loan.id }}</td>
                    <td>
                        <a href="{{ path('app_book_show', {id: loan.book.id}) }}" class="text-decoration-none fw-semibold">
                            {{ loan.book.titre }}
                        </a>
                    </td>
                    <td class="text-muted">{{ loan.user.email }}</td>
                    <td>{{ loan.dateEmprunt|date('d/m/Y') }}</td>
                    <td>
                        {{ loan.dateRetourPrevue|date('d/m/Y') }}
                        {% if loan.statut != 'rendu' and loan.dateRetourPrevue < date() %}
                            <i class="bi bi-exclamation-circle text-danger ms-1" title="En retard"></i>
                        {% endif %}
                    </td>
                    <td>
                        {% if loan.statut == 'en_cours' %}
                            <span class="badge bg-info text-dark">En cours</span>
                        {% elseif loan.statut == 'rendu' %}
                            <span class="badge bg-success">Rendu</span>
                        {% else %}
                            <span class="badge bg-danger">En retard</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="{{ path('admin_loans_edit', {id: loan.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_loans_delete', {id: loan.id}) }}"
                                  onsubmit="return confirm('Supprimer cet emprunt ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ loan.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Aucun emprunt trouvé.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-transparent text-muted small">
        {{ loans|length }} emprunt(s) au total
    </div>
</div>
{% endblock %}
