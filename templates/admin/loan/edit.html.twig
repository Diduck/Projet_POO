{% extends 'base.html.twig' %}

{% block title %}Modifier l'emprunt #{{ loan.id }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Admin</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_loans_list') }}">Emprunts</a></li>
        <li class="breadcrumb-item active">Modifier #{{ loan.id }}</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h2 class="fw-bold"><i class="bi bi-pencil me-2 text-success"></i>Modifier l'emprunt</h2>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-light border mb-4">
                    <strong><i class="bi bi-book me-1"></i>Livre :</strong> {{ loan.book.titre }}<br>
                    <strong><i class="bi bi-person me-1"></i>Emprunteur :</strong> {{ loan.user.email }}<br>
                    <strong><i class="bi bi-calendar me-1"></i>Date d'emprunt :</strong> {{ loan.dateEmprunt|date('d/m/Y H:i') }}
                </div>

                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                {{ form_row(form.dateRetourPrevue) }}
                {{ form_row(form.statut) }}
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_loans_list') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Annuler
                    </a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
