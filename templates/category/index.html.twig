{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold"><i class="bi bi-tags me-2 text-primary"></i>Catégories</h1>
</div>

{% if categories|length > 0 %}
    <div class="row g-4">
        {% for category in categories %}
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-folder2-open text-primary fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0 fw-bold">{{ category.nom }}</h5>
                                <small class="text-muted">{{ category.books|length }} livre(s)</small>
                            </div>
                        </div>
                        {% if category.description %}
                            <p class="card-text text-muted small mb-3">
                                {{ category.description|length > 120 ? category.description|slice(0, 120) ~ '...' : category.description }}
                            </p>
                        {% endif %}
                        <a href="{{ path('app_books', {category: category.id}) }}" class="btn btn-primary btn-sm">
                            <i class="bi bi-books me-1"></i>Voir les livres
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-tags display-4 d-block mb-3"></i>
        <h4>Aucune catégorie</h4>
        <p>Il n'y a pas encore de catégories disponibles.</p>
    </div>
{% endif %}
{% endblock %}
