{% extends 'base.html.twig' %}

{% block title %}Mes emprunts{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold"><i class="bi bi-bookmark me-2 text-primary"></i>Mes emprunts</h1>
    <a href="{{ path('app_books') }}" class="btn btn-primary">
        <i class="bi bi-search me-1"></i>Chercher un livre
    </a>
</div>

{% if loans|length > 0 %}
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><i class="bi bi-book me-1"></i>Livre</th>
                        <th><i class="bi bi-person me-1"></i>Auteur</th>
                        <th><i class="bi bi-calendar me-1"></i>Emprunté le</th>
                        <th><i class="bi bi-calendar-check me-1"></i>Retour prévu</th>
                        <th><i class="bi bi-info-circle me-1"></i>Statut</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for loan in loans %}
                        <tr>
                            <td>
                                <a href="{{ path('app_book_show', {id: loan.book.id}) }}" class="text-decoration-none fw-semibold">
                                    {{ loan.book.titre }}
                                </a>
                            </td>
                            <td class="text-muted">{{ loan.book.auteur ?? '—' }}</td>
                            <td>{{ loan.dateEmprunt|date('d/m/Y') }}</td>
                            <td>
                                {{ loan.dateRetourPrevue|date('d/m/Y') }}
                                {% if loan.statut != 'rendu' and loan.dateRetourPrevue < date() %}
                                    <span class="badge bg-danger ms-1">En retard</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if loan.statut == 'en_cours' %}
                                    <span class="badge bg-info text-dark">En cours</span>
                                {% elseif loan.statut == 'rendu' %}
                                    <span class="badge bg-success">Rendu</span>
                                {% elseif loan.statut == 'en_retard' %}
                                    <span class="badge bg-danger">En retard</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_book_show', {id: loan.book.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 d-flex gap-3">
        <span class="badge bg-info text-dark fs-6 py-2 px-3">
            <i class="bi bi-bookmark me-1"></i>
            {{ loans|filter(l => l.statut == 'en_cours')|length }} en cours
        </span>
        <span class="badge bg-success fs-6 py-2 px-3">
            <i class="bi bi-check-circle me-1"></i>
            {{ loans|filter(l => l.statut == 'rendu')|length }} rendu(s)
        </span>
        <span class="badge bg-danger fs-6 py-2 px-3">
            <i class="bi bi-exclamation-triangle me-1"></i>
            {{ loans|filter(l => l.statut == 'en_retard')|length }} en retard
        </span>
    </div>
{% else %}
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-bookmark display-4 d-block mb-3"></i>
        <h4>Aucun emprunt</h4>
        <p class="mb-3">Vous n'avez pas encore emprunté de livre.</p>
        <a href="{{ path('app_books') }}" class="btn btn-primary">
            <i class="bi bi-search me-1"></i>Parcourir le catalogue
        </a>
    </div>
{% endif %}
{% endblock %}
