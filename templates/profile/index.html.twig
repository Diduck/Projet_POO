{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card border-0 shadow-sm overflow-hidden">

            {# Header #}
            <div class="py-4 px-3 text-center text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                     style="width:72px;height:72px;background:rgba(255,255,255,.2);">
                    <i class="bi bi-person-fill" style="font-size:2.2rem;color:#fff;"></i>
                </div>
                <h5 class="fw-bold mb-1">{{ user.email }}</h5>
                {% for role in user.roles %}
                    {% if role == 'ROLE_ADMIN' %}
                        <span class="badge bg-warning text-dark">Administrateur</span>
                    {% else %}
                        <span class="badge bg-white text-primary">Membre</span>
                    {% endif %}
                {% endfor %}
            </div>

            <div class="card-body p-4">
                {# Stats row #}
                <div class="row g-3 mb-4 text-center">
                    <div class="col-4">
                        <div class="p-2 rounded bg-light">
                            <div class="fs-4 fw-bold text-primary">{{ loans|length }}</div>
                            <small class="text-muted">Total</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-light">
                            <div class="fs-4 fw-bold text-info">{{ loans|filter(l => l.statut == 'en_cours')|length }}</div>
                            <small class="text-muted">En cours</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-light">
                            <div class="fs-4 fw-bold {{ loans|filter(l => l.statut == 'en_retard')|length > 0 ? 'text-danger' : 'text-secondary' }}">
                                {{ loans|filter(l => l.statut == 'en_retard')|length }}
                            </div>
                            <small class="text-muted">En retard</small>
                        </div>
                    </div>
                </div>

                <div class="d-grid">
                    <a href="{{ path('app_loans') }}" class="btn btn-primary btn-lg">
                        <i class="bi bi-list-check me-2"></i>Voir mes emprunts
                    </a>
                </div>

                {% if is_granted('ROLE_ADMIN') %}
                    <div class="d-grid mt-2">
                        <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-warning">
                            <i class="bi bi-speedometer2 me-2"></i>Tableau de bord admin
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
