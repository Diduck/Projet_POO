{% extends 'base.html.twig' %}

{% block title %}Catalogue des livres{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold"><i class="bi bi-collection-fill me-2 text-primary"></i>Catalogue des livres</h1>
</div>

{# Search bar #}
<form method="GET" action="{{ path('app_books') }}" class="mb-4">
    <div class="input-group">
        <input type="text" name="q" class="form-control form-control-lg" placeholder="Rechercher par titre ou auteur..." value="{{ search ?? '' }}">
        <button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i>Rechercher</button>
        {% if search or selectedCategory %}
            <a href="{{ path('app_books') }}" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle me-1"></i>Effacer
            </a>
        {% endif %}
    </div>
</form>

{# Category filters #}
<div class="mb-4">
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <span class="text-muted small me-1"><i class="bi bi-filter me-1"></i>Filtrer :</span>
        <a href="{{ path('app_books') }}" class="btn btn-sm {{ not selectedCategory and not search ? 'btn-primary' : 'btn-outline-primary' }}">
            Toutes les catégories
        </a>
        {% for category in categories %}
            <a href="{{ path('app_books', {category: category.id}) }}"
               class="btn btn-sm {{ selectedCategory == category.id ? 'btn-primary' : 'btn-outline-primary' }}">
                {{ category.nom }}
                <span class="badge bg-white text-primary ms-1">{{ category.books|length }}</span>
            </a>
        {% endfor %}
    </div>
</div>

{# Results count #}
<p class="text-muted small mb-3">
    <i class="bi bi-list-ul me-1"></i>{{ books|length }} livre(s) trouvé(s)
    {% if search %} pour "<strong>{{ search }}</strong>"{% endif %}
    {% if selectedCategory %}
        dans <strong>{{ categories|filter(c => c.id == selectedCategory)|first.nom }}</strong>
    {% endif %}
</p>

{% if books|length > 0 %}
    <div class="row g-3">
        {% for book in books %}
            <div class="col-sm-6 col-md-4 col-xl-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex flex-column p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            {% if book.disponible %}
                                <span class="badge bg-success">Disponible</span>
                            {% else %}
                                <span class="badge bg-danger">Indisponible</span>
                            {% endif %}
                            {% if book.category %}
                                <span class="badge bg-secondary bg-opacity-75 text-white">{{ book.category.nom }}</span>
                            {% endif %}
                        </div>
                        <h6 class="fw-bold mb-1 lh-sm">{{ book.titre }}</h6>
                        {% if book.auteur %}
                            <p class="text-muted small mb-0">
                                <i class="bi bi-person me-1"></i>{{ book.auteur }}
                            </p>
                        {% endif %}
                        {% if book.datePublication %}
                            <p class="text-muted small mb-0">
                                <i class="bi bi-calendar3 me-1"></i>{{ book.datePublication|date('Y') }}
                            </p>
                        {% endif %}
                        <a href="{{ path('app_book_show', {id: book.id}) }}" class="btn btn-sm btn-primary mt-auto pt-2">
                            <i class="bi bi-eye me-1"></i>Voir le détail
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-search display-4 d-block mb-3"></i>
        <h4>Aucun livre trouvé</h4>
        <p class="mb-3">Aucun livre ne correspond à votre recherche.</p>
        <a href="{{ path('app_books') }}" class="btn btn-primary">Voir tous les livres</a>
    </div>
{% endif %}
{% endblock %}
