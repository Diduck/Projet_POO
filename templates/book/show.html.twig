{% extends 'base.html.twig' %}

{% block title %}{{ book.titre }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_books') }}">Livres</a></li>
        <li class="breadcrumb-item active">{{ book.titre }}</li>
    </ol>
</nav>

<div class="row g-4">
    {# Left panel — metadata + action #}
    <div class="col-md-3">
        <div class="card border-0 shadow-sm overflow-hidden text-center">
            <div class="py-4 px-3 {{ book.disponible ? 'bg-success' : 'bg-danger' }} bg-opacity-10">
                <i class="bi bi-book display-1 {{ book.disponible ? 'text-success' : 'text-danger' }}"></i>
            </div>
            <div class="card-body p-3">
                <span class="badge {{ book.disponible ? 'bg-success' : 'bg-danger' }} fs-6 mb-3 d-block">
                    <i class="bi {{ book.disponible ? 'bi-check-circle' : 'bi-x-circle' }} me-1"></i>
                    {{ book.disponible ? 'Disponible' : 'Indisponible' }}
                </span>

                {% if book.category %}
                    <div class="mb-2 pb-2 border-bottom">
                        <small class="text-muted d-block mb-1">Catégorie</small>
                        <a href="{{ path('app_books', {category: book.category.id}) }}" class="badge bg-secondary text-decoration-none">
                            {{ book.category.nom }}
                        </a>
                    </div>
                {% endif %}

                {% if book.datePublication %}
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Publié en</small>
                        <strong>{{ book.datePublication|date('Y') }}</strong>
                    </div>
                {% endif %}

                {% if book.disponible %}
                    {% if is_granted('ROLE_USER') %}
                        <form method="post" action="{{ path('app_book_borrow', {id: book.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('borrow') }}">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="bi bi-bookmark-plus me-1"></i>Emprunter
                            </button>
                        </form>
                        <small class="text-muted d-block mt-2"><i class="bi bi-clock me-1"></i>Durée : 14 jours</small>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-success w-100">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Se connecter pour emprunter
                        </a>
                    {% endif %}
                {% else %}
                    <button class="btn btn-secondary w-100" disabled>
                        <i class="bi bi-bookmark-x me-1"></i>Non disponible
                    </button>
                {% endif %}
            </div>
        </div>
    </div>

    {# Right panel — title, author, résumé #}
    <div class="col-md-9">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h1 class="fw-bold mb-1">{{ book.titre }}</h1>

                {% if book.auteur %}
                    <p class="text-muted fs-5 mb-4">
                        <i class="bi bi-person me-1"></i>{{ book.auteur }}
                    </p>
                {% endif %}

                {% if book.resume %}
                    <h6 class="text-uppercase text-muted fw-semibold mb-2" style="letter-spacing:.05em;">
                        <i class="bi bi-file-text me-1"></i>Résumé
                    </h6>
                    <p class="lh-lg text-secondary">{{ book.resume }}</p>
                {% endif %}

                <div class="d-flex gap-2 mt-4 pt-3 border-top">
                    <a href="{{ path('app_books') }}" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i>Retour au catalogue
                    </a>
                    {% if book.category %}
                        <a href="{{ path('app_books', {category: book.category.id}) }}" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-tag me-1"></i>Voir plus de {{ book.category.nom }}
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
